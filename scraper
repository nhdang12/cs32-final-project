import csv
import ast  # important for parsing list strings
from recipe import Recipe
from recipe_database import RecipeDatabase


def load_recipes_from_kaggle_csv(file_path):
    db = RecipeDatabase()

    with open(file_path, "r", encoding="utf-8") as f:
        reader = csv.DictReader(f)

        for i, row in enumerate(reader):
            try:
                # --- Basic fields ---
                recipe_id = int(row.get("id", i))
                name = row.get("name", "").strip()

                if not name:
                    continue

                # --- Cook time ---
                cook_time = int(row.get("minutes", 0))

                # --- Ingredients (string → list) ---
                ingredients_raw = row.get("ingredients", "[]")
                ingredients = ast.literal_eval(ingredients_raw)

                # --- Instructions (string → list) ---
                steps_raw = row.get("steps", "[]")
                instructions = ast.literal_eval(steps_raw)

                # --- Category (optional, from tags) ---
                tags_raw = row.get("tags", "[]")
                tags = ast.literal_eval(tags_raw) if tags_raw else []
                category = tags[0] if tags else None

                # --- Create Recipe ---
                recipe = Recipe(
                    recipe_id=recipe_id,
                    name=name,
                    ingredients=ingredients,
                    cook_time=cook_time,
                    category=category,
                    instructions=instructions,
                    source="Kaggle"
                )

                db.add_recipe(recipe)

            except Exception as e:
                print(f"Skipping row {i}: {e}")

    return db
